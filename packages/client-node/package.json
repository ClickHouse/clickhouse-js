{
  "name": "@clickhouse/client",
  "description": "Official JS client for ClickHouse DB - Node.js implementation",
  "homepage": "https://clickhouse.com",
  "version": "1.23.0",
  "license": "Apache-2.0",
  "keywords": [
    "clickhouse",
    "sql",
    "client"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ClickHouse/clickhouse-js.git"
  },
  "private": false,
  "engines": {
    "node": ">=20"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "skills",
    "CHANGELOG.md"
  ],
  "agents": {
    "skills": [
      {
        "name": "clickhouse-js-node-coding",
        "path": "./skills/clickhouse-js-node-coding"
      },
      {
        "name": "clickhouse-js-node-troubleshooting",
        "path": "./skills/clickhouse-js-node-troubleshooting"
      },
      {
        "name": "clickhouse-js-node-rowbinary",
        "path": "./skills/clickhouse-js-node-rowbinary"
      }
    ]
  },
  "scripts": {
    "pack": "npm pack",
    "prepack": "rm -rf skills && cp ../../LICENSE . && cp -r ../../skills . && RBP=skills/clickhouse-js-node-rowbinary && rm -rf $RBP/tests $RBP/node_modules $RBP/dist $RBP/package.json $RBP/package-lock.json $RBP/tsconfig.json $RBP/tsconfig.build.json $RBP/vitest.config.ts $RBP/.gitignore $RBP/LICENSE $RBP/eval_result*.md",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --max-warnings=0 .",
    "lint:fix": "eslint . --fix",
    "build": "rm -rf dist; tsc"
  },
  "dependencies": {},
  "devDependencies": {
    "simdjson": "^0.9.2"
  }
}
