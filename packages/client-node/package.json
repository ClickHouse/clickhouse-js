{
  "name": "@clickhouse/client",
  "description": "Official JS client for ClickHouse DB - Node.js implementation",
  "homepage": "https://clickhouse.com",
  "version": "1.18.4",
  "license": "Apache-2.0",
  "keywords": [
    "clickhouse",
    "sql",
    "client"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ClickHouse/clickhouse-js.git"
  },
  "private": false,
  "engines": {
    "node": ">=16"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "skills"
  ],
  "agents": {
    "skills": [
      {
        "name": "clickhouse-js-node-troubleshooting",
        "path": "./skills/clickhouse-js-node-troubleshooting"
      }
    ]
  },
  "scripts": {
    "prepack": "cp ../../README.md ../../LICENSE . && cp -r ../../skills .",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --max-warnings=0 .",
    "lint:fix": "eslint . --fix",
    "build": "rm -rf dist; tsc"
  },
  "dependencies": {
    "@clickhouse/client-common": "1.18.4"
  },
  "devDependencies": {
    "simdjson": "^0.9.2"
  }
}
